									"    method: \"GET\",",
									"    header: {",
									"        'Authorization': pm.request.headers.get(\"Authorization\"),",
									"        'Content-Type': 'application/json'",
									"    }",
									"}, function (err, res) {",
									"    pm.test(\"Project no longer exists\", function() {",
									"        pm.expect(res.code).to.be.oneOf([400, 404]);",
