				{
					"name": "Create New Project",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Project is created successfully\", function () {",
									"    pm.expect(response.id).to.be.a('number');",
									"    pm.expect(response.name).to.eql(pm.variables.get(\"projectName\"));",
									"    pm.expect(response.announcement).to.eql(pm.variables.get(\"projectAnnouncement\"));",
									"    pm.expect(response.show_announcement).to.eql(pm.variables.get(\"projectShowAnnouncement\"));",
									"});",
									"",
									"// Save project ID for subsequent tests",
									"if (response && response.id) {",
									"    pm.collectionVariables.set(\"projectId\", response.id);",
									"    console.log(\"Project created with ID: \" + response.id);",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Generate random project data",
									"const projectName = \"Test Project-\" + Math.floor(Math.random() * 10000);",
									"const projectAnnouncement = \"This is an automated test project created on \" + new Date().toISOString();",
									"const projectShowAnnouncement = false;",
									"",
									"// Set variables for testing",
									"pm.variables.set(\"projectName\", projectName);",
									"pm.variables.set(\"projectAnnouncement\", projectAnnouncement);",
									"pm.variables.set(\"projectShowAnnouncement\", projectShowAnnouncement);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"{{projectName}}\",\n    \"announcement\": \"{{projectAnnouncement}}\",\n    \"show_announcement\": {{projectShowAnnouncement}}\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/add_project",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"add_project"
							]
						},
						"description": "Create a new project in TestRail"
					},
					"response": []
				},
