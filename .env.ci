# CI Environment Configuration
# This is a template for CI environments - do not add real credentials here
# Real credentials should be provided as CI secrets

# Environment
TEST_ENV=ci

# Application URLs
BASE_URL=https://ci.testrail.instance.com/
API_URL=https://ci.testrail.instance.com/index.php?/api/v2/

# These values should come from CI secrets
USER_EMAIL=
USER_PASSWORD=
TESTRAIL_EMAIL=
TESTRAIL_PASSWORD=
TESTRAIL_API_KEY=

# Test Configuration
HEADLESS=true
SLOWMO=0
TIMEOUT=60000
RETRY_COUNT=2

# Browser Configuration
BROWSER=chromium

# CI Configuration
CI=true
