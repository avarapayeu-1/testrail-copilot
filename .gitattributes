# Set default behavior to automatically normalize line endings
* text=auto

# Shell scripts should have Unix endings
*.sh text eol=lf

# Batch and PowerShell scripts should have Windows endings
*.bat text eol=crlf
*.ps1 text eol=crlf

# Docker files should have Unix endings
Dockerfile text eol=lf
.dockerignore text eol=lf
docker-compose.yml text eol=lf

# Explicitly declare text files that should always be normalized and converted
# to native line endings on checkout
*.js text
*.ts text
*.json text
*.md text
*.yml text
*.yaml text

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar.gz binary
